clear
# 3C-SiC (zinc-blende), Gao-Weber 2002 potential (a0 = 4.36 A, experimental)
units           metal
atom_style      atomic
boundary        p p p

lattice         diamond 4.3596
region          box block 0 32 0 32 0 32
create_box      2 box
create_atoms    1 region box basis 5 2 basis 6 2 basis 7 2 basis 8 2

pair_style      gw/zbl
pair_coeff      * * potentials/SiC.gw.zbl Si C

mass            1 28.085
mass            2 12.011

neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

thermo          100
thermo_style    custom step temp pe ke etotal press vol
thermo_modify   flush yes

min_style       cg
minimize        1.0e-6 1.0e-8 1000 10000

velocity        all create 300.0 54321 dist gaussian
fix             1 all npt temp 300.0 300.0 0.1 iso 0.0 0.0 1.0
run             5000
unfix           1

# WS reference at the relaxed lattice constant
write_data      structures/perfect_lattice_SiC.data

write_restart   outputs/sic_equil.restart
